# VibePrint Environment Configuration
# Copy this to .env and fill in your values

# OpenAI API Key (required for vibe interpretation)
OPENAI_API_KEY=sk-your-key-here

# Server config
HOST=127.0.0.1
PORT=8000

# Tool paths (optional — auto-detected if in PATH)
BLENDER_PATH=blender
PRUSA_SLICER_PATH=prusa-slicer-console.exe

# Output directories
OUTPUT_DIR=../output
